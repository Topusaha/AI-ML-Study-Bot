# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Ollama model for LLM inference (swap for mistral or qwen2.5 for better quality)
OLLAMA_MODEL=tinyllama

# Guardrail thresholds (tune after inspecting refusal logs)
COSINE_DISTANCE_THRESHOLD=0.8

# Passkey for the Human-in-the-Loop evaluation tab (SHA-256 safe to store here)
HITL_PASSKEY=change_me
